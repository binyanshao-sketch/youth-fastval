/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 主题色 */
.text-primary {
  color: #E54D42;
}

.bg-primary {
  background-color: #E54D42;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #E54D42 0%, #F37B1D 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.btn-disabled {
  background: #ccc;
  color: #fff;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 间距 */
.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

/* 文字 */
.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

.text-gray {
  color: #999;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 36rpx;
}

.text-xl {
  font-size: 48rpx;
}

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 动画 */
@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.shake {
  animation: shake 0.3s ease-in-out;
}

/* 红包雨动画 */
@keyframes redpacket-rain {
  0% {
    transform: translateY(-100rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(100vh);
    opacity: 1;
  }
}

.redpacket-rain {
  animation: redpacket-rain 2s linear infinite;
}
