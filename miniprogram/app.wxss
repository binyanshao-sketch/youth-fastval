page {
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(123, 229, 217, 0.24), transparent 28%),
    radial-gradient(circle at bottom left, rgba(86, 170, 255, 0.18), transparent 24%),
    linear-gradient(180deg, #f4fbff 0%, #edf7fb 42%, #f2f8f8 100%);
  color: #183b60;
  font-size: 28rpx;
}

view,
text,
button,
input,
swiper,
swiper-item,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.glass-card {
  background: rgba(249, 254, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(17, 74, 129, 0.08);
  backdrop-filter: blur(18rpx);
}

.surface-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 34rpx rgba(15, 70, 124, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #163b63;
}

.section-subtitle {
  font-size: 24rpx;
  color: #6f879a;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #eef8ff;
}

.hero-title {
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 800;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.74;
  color: rgba(232, 245, 255, 0.88);
}

.primary-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0d5fa8 0%, #1ca391 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 30rpx rgba(13, 95, 168, 0.22);
}

.primary-btn.is-disabled {
  background: linear-gradient(135deg, #c1d0da 0%, #aebec8 100%);
  box-shadow: none;
}

.secondary-btn {
  height: 88rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(13, 95, 168, 0.26);
  background: rgba(255, 255, 255, 0.94);
  color: #0d5f95;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tiny-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(27, 161, 145, 0.1);
  color: #117a70;
  font-size: 22rpx;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-chip.active {
  background: rgba(27, 161, 145, 0.14);
  color: #117a70;
}

.status-chip.pending {
  background: rgba(240, 192, 92, 0.18);
  color: #9b6b12;
}

.status-chip.processing {
  background: rgba(13, 95, 168, 0.12);
  color: #0d5fa8;
}

.status-chip.failed {
  background: rgba(231, 103, 83, 0.14);
  color: #af4938;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
}

.summary-value {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #163b63;
}

.summary-label {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f879a;
}

.metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.metric-main {
  font-size: 42rpx;
  font-weight: 800;
  color: #163b63;
}

.metric-caption {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6f879a;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(13, 95, 168, 0.08);
  color: #0d5fa8;
}

.empty-panel {
  padding: 40rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
  color: #6f879a;
  line-height: 1.78;
}

.poster-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 38rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 32%),
    linear-gradient(145deg, #0b5a9d 0%, #0a478b 48%, #097770 100%);
  color: #eef8ff;
  box-shadow: 0 24rpx 46rpx rgba(13, 79, 136, 0.22);
}

.poster-card::before,
.poster-card::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.poster-card::before {
  width: 220rpx;
  height: 220rpx;
  right: -40rpx;
  top: -80rpx;
}

.poster-card::after {
  width: 180rpx;
  height: 180rpx;
  left: -40rpx;
  bottom: -80rpx;
}

.page-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.divider {
  width: 100%;
  height: 1rpx;
  background: rgba(111, 135, 154, 0.18);
}

.ring {
  position: relative;
  border-radius: 50%;
}

@keyframes floatPulse {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.float-pulse {
  animation: floatPulse 2.6s ease-in-out infinite;
}

.startup-overlay {
  position: fixed;
  inset: 0;
  z-index: 199;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top right, rgba(58, 188, 232, 0.2), transparent 34%),
    radial-gradient(circle at bottom left, rgba(54, 197, 135, 0.2), transparent 34%),
    rgba(233, 247, 255, 0.7);
  backdrop-filter: blur(8rpx);
}

.startup-card {
  width: 520rpx;
  padding: 28rpx 30rpx;
  border-radius: 30rpx;
  background: rgba(248, 255, 255, 0.96);
  box-shadow: 0 22rpx 46rpx rgba(14, 96, 141, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.startup-spinner {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(18, 134, 201, 0.22);
  border-top-color: #1286c9;
  animation: startupSpin 0.95s linear infinite;
}

.startup-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.startup-title {
  font-size: 30rpx;
  color: #0f5f94;
  font-weight: 800;
}

.startup-desc {
  font-size: 24rpx;
  color: #5f8397;
}

@keyframes startupSpin {
  to {
    transform: rotate(360deg);
  }
}
