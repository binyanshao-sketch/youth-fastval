@import "../lottery/index.wxss";
@import "../lucky-bag/result.wxss";

.home-page {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  overflow: hidden;
}

.stagger-item {
  opacity: 0;
  transform: translateY(52rpx);
  transition: transform 620ms cubic-bezier(0.2, 0.9, 0.24, 1.08), opacity 520ms ease;
}

.page-entered .stagger-item {
  opacity: 1;
  transform: translateY(0);
}

.page-entered .stage-1 {
  transition-delay: 60ms;
}

.page-entered .stage-2 {
  transition-delay: 130ms;
}

.page-entered .stage-3 {
  transition-delay: 210ms;
}

.page-entered .stage-4 {
  transition-delay: 300ms;
}

.home-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 42rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.2), transparent 28%),
    linear-gradient(145deg, #0d5b9c 0%, #0b4b87 52%, #097770 100%);
  color: #eef8ff;
  box-shadow: 0 28rpx 56rpx rgba(13, 79, 136, 0.22);
}

.hero-orbit {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(8rpx);
}

.orbit-a {
  width: 260rpx;
  height: 260rpx;
  right: -40rpx;
  top: -20rpx;
  background: radial-gradient(circle, rgba(118, 236, 214, 0.3) 0%, rgba(118, 236, 214, 0) 72%);
}

.orbit-b {
  width: 300rpx;
  height: 300rpx;
  left: -80rpx;
  bottom: -120rpx;
  background: radial-gradient(circle, rgba(94, 180, 255, 0.22) 0%, rgba(94, 180, 255, 0) 72%);
}

.hero-badge {
  margin-bottom: 20rpx;
}

.home-hero .hero-title,
.home-hero .hero-desc,
.home-hero .hero-actions,
.home-hero .countdown {
  position: relative;
  z-index: 1;
}

.home-hero .hero-title {
  color: #eef8ff;
}

.hero-title .accent {
  display: block;
  margin-top: 12rpx;
  color: #bff4e5;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 34rpx;
}

.countdown {
  margin-top: 28rpx;
  padding: 24rpx;
}

.section-title.small {
  font-size: 30rpx;
}

.section-subtitle.block {
  display: block;
  margin-top: 10rpx;
}

.section-head-stack {
  align-items: flex-start;
}

.countdown-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.count-item {
  padding: 18rpx 12rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  text-align: center;
}

.count-value {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
}

.count-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(232, 245, 255, 0.76);
}

.flow,
.home-lottery-shell,
.welfare {
  position: relative;
  z-index: 1;
  padding: 28rpx;
}

.flow-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.flow-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.flow-index {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #0d5fa8 0%, #1ca391 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 26rpx rgba(13, 95, 168, 0.2);
}

.flow-body {
  flex: 1;
  padding-top: 6rpx;
}

.flow-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #163b63;
}

.flow-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.76;
  color: #6f879a;
}

.home-lottery-shell {
  transition: box-shadow 280ms ease, transform 280ms ease;
}

.lottery-spotlight {
  box-shadow: 0 0 0 2rpx rgba(80, 206, 198, 0.34), 0 22rpx 54rpx rgba(14, 77, 137, 0.16);
  transform: translateY(-2rpx);
}

.poster-quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.poster-quick-actions .mini-btn {
  flex: 1 1 200rpx;
}

.mode-switch-v3 {
  padding: 10rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(14, 84, 145, 0.1), rgba(28, 163, 145, 0.1));
}

.home-page .switch-track {
  gap: 10rpx;
}

.home-page .switch-item {
  height: 76rpx;
  border-radius: 22rpx;
  background: transparent;
  color: #6f879a;
  transition: all 220ms ease;
}

.home-page .switch-item.active {
  background: #ffffff;
  color: #0d5fa8;
  box-shadow: 0 14rpx 28rpx rgba(12, 95, 168, 0.12);
}

.lottery-stage-card {
  position: relative;
  overflow: hidden;
}

.lottery-stage-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(128, 234, 216, 0.16), transparent 32%);
  pointer-events: none;
}

.home-page .wheel-stage {
  height: 760rpx;
}

.home-page .wheel-body {
  border: 20rpx solid rgba(10, 84, 145, 0.18);
  box-shadow: 0 0 0 10rpx rgba(24, 177, 162, 0.1);
}

.wheel-body-v3 {
  background: radial-gradient(circle at center, rgba(245, 251, 255, 0.96), rgba(232, 247, 249, 0.98));
}

.wheel-pointer-v3 {
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 52rpx solid #efc05c;
  filter: drop-shadow(0 8rpx 16rpx rgba(208, 157, 39, 0.32));
}

.home-page .wheel-center {
  box-shadow: 0 22rpx 34rpx rgba(13, 95, 168, 0.24);
}

.home-page .grid-cell {
  position: relative;
  min-height: 176rpx;
  border-radius: 28rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  overflow: visible;
}

.home-page .grid-cell.active {
  box-shadow: none;
}

.home-page .grid-cell.active::after {
  content: '';
  position: absolute;
  inset: -12rpx;
  border-radius: 34rpx;
  border: 3rpx solid rgba(40, 198, 178, 0.36);
  box-shadow: 0 0 0 0 rgba(40, 198, 178, 0.18);
  animation: gridHalo 1.2s ease-out infinite;
  pointer-events: none;
}

.home-page .grid-prize {
  box-shadow: 0 16rpx 30rpx rgba(14, 78, 137, 0.08);
}

.home-page .grid-cell.center {
  background: linear-gradient(145deg, #0d5fa8 0%, #1ba191 100%);
}

.home-result-card {
  padding: 28rpx;
}

.compact-actions {
  margin-top: 8rpx;
}

.rule-text {
  font-size: 25rpx;
  line-height: 1.82;
  color: #587385;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-card {
  min-height: 230rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.quick-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(13, 95, 168, 0.12), rgba(27, 161, 145, 0.12));
  color: #0d5fa8;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #163b63;
}

.quick-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: #6f879a;
}

.poster-popup {
  position: fixed;
  inset: 0;
  z-index: 1000;
}

.poster-popup-mask {
  position: absolute;
  inset: 0;
  background: rgba(7, 34, 61, 0.42);
  backdrop-filter: blur(10rpx);
}

.poster-popup-panel {
  position: relative;
  z-index: 1;
  min-height: 100%;
  padding: 72rpx 28rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20rpx;
}

.poster-modal-card,
.poster-popup-actions {
  width: 100%;
}

.poster-kicker {
  margin-bottom: 18rpx;
}

.poster-popup-actions {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poster-popup-actions .primary-btn,
.poster-popup-actions .secondary-btn {
  width: 100%;
}

@keyframes gridHalo {
  0% {
    transform: scale(0.94);
    opacity: 0.88;
    box-shadow: 0 0 0 0 rgba(40, 198, 178, 0.24);
  }
  100% {
    transform: scale(1.04);
    opacity: 0.1;
    box-shadow: 0 0 0 18rpx rgba(40, 198, 178, 0);
  }
}
