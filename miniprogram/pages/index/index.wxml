<view class="page-shell home-page {{pageEntered ? 'page-entered' : ''}}">
  <view class="hero home-hero surface-card stagger-item stage-1">
    <view class="hero-orbit orbit-a"></view>
    <view class="hero-orbit orbit-b"></view>
    <view class="hero-badge hero-kicker">{{statusText}}</view>
    <view class="hero-title">
      青春福袋
      <text class="hero-title accent">红包、海报、抽奖一屏衔接</text>
    </view>
    <view class="hero-desc">
      以宜宾三江交汇和竹海风景为灵感，领取福袋后海报随机弹出。抽奖已切换为独立页面，体验更清晰。
    </view>

    <view class="hero-actions">
      <button
        class="primary-btn {{!isActive ? 'is-disabled' : ''}}"
        disabled="{{!isActive}}"
        bindtap="onReceiveTap"
      >
        {{hasReceived ? '再弹一张荣誉海报' : '领取青春福袋'}}
      </button>
      <button class="secondary-btn" bindtap="goToPolicy">查看青年政策福利</button>
    </view>

    <view wx:if="{{countdown}}" class="countdown glass-card">
      <view class="section-head">
        <text class="section-title small">开袋倒计时</text>
        <text class="section-subtitle">活动开始后即可领取红包并解锁抽奖页</text>
      </view>
      <view class="countdown-grid">
        <view class="count-item">
          <text class="count-value">{{countdown.days}}</text>
          <text class="count-label">天</text>
        </view>
        <view class="count-item">
          <text class="count-value">{{countdown.hours}}</text>
          <text class="count-label">时</text>
        </view>
        <view class="count-item">
          <text class="count-value">{{countdown.minutes}}</text>
          <text class="count-label">分</text>
        </view>
        <view class="count-item">
          <text class="count-value">{{countdown.seconds}}</text>
          <text class="count-label">秒</text>
        </view>
      </view>
    </view>
  </view>

  <view class="flow glass-card stagger-item stage-2">
    <view class="section-head">
      <text class="section-title">三江青年体验路线</text>
      <text class="section-subtitle">领取、海报、抽奖已串成完整流程</text>
    </view>
    <view class="flow-list">
      <view class="flow-item">
        <view class="flow-index">01</view>
        <view class="flow-body">
          <text class="flow-title">九选一领取红包</text>
          <text class="flow-text">先在福袋页选中一个红包，完成拆袋领取，结果会自动同步回首页。</text>
        </view>
      </view>
      <view class="flow-item">
        <view class="flow-index">02</view>
        <view class="flow-body">
          <text class="flow-title">随机弹出荣誉海报</text>
          <text class="flow-text">领取完成后，系统会随机展示红包海报或分享海报，增强活动仪式感。</text>
        </view>
      </view>
      <view class="flow-item">
        <view class="flow-index">03</view>
        <view class="flow-body">
          <text class="flow-title">进入独立抽奖页面</text>
          <text class="flow-text">抽奖玩法已迁移到独立页面，进入后可查看完整奖池并参与抽奖。</text>
        </view>
      </view>
    </view>
  </view>

  <view
    id="lottery-section"
    class="glass-card home-lottery-shell stagger-item stage-3"
  >
    <view class="section-head section-head-stack">
      <view>
        <text class="section-title">抽奖入口</text>
        <text class="section-subtitle block">
          {{hasReceived ? '抽奖已迁移到独立页面，点击下方按钮进入完整抽奖流程。' : '领取青春福袋后可进入独立抽奖页参与活动。'}}
        </text>
      </view>
      <text class="status-chip {{hasDrawnLottery ? 'active' : 'pending'}}">{{hasDrawnLottery ? '已抽奖' : '待解锁'}}</text>
    </view>

    <view wx:if="{{hasReceived}}" class="page-actions">
      <button class="primary-btn" bindtap="goToLottery">{{hasDrawnLottery ? '查看抽奖结果' : '进入抽奖页'}}</button>
      <view class="poster-quick-actions">
        <button class="secondary-btn mini-btn" bindtap="openRandomPoster">随机弹出海报</button>
        <button class="secondary-btn mini-btn" bindtap="openSharePoster">分享海报</button>
        <button class="secondary-btn mini-btn" bindtap="goToResult">查看荣誉卡片</button>
      </view>
    </view>
    <view wx:else class="empty-panel">
      先领取青春福袋，再进入独立抽奖页参与活动。
    </view>
  </view>

  <view wx:if="{{hasReceived}}" class="welfare glass-card stagger-item stage-4">
    <view class="section-head">
      <text class="section-title">我的当前权益</text>
      <text class="section-subtitle">已领取内容可直接进入明细页</text>
    </view>
    <view class="list-stack">
      <view class="list-card metric-row" bindtap="goToRedpacket">
        <view>
          <text class="metric-main">¥{{myRedpacket ? myRedpacket.amount : '0.00'}}</text>
          <text class="metric-caption">微信红包 {{myRedpacket ? (myRedpacket.status === 2 ? '已发放' : '发放中') : '待发放'}}</text>
        </view>
        <text class="tiny-chip">查看红包</text>
      </view>
      <view class="list-card metric-row" bindtap="goToCoupon">
        <view>
          <text class="metric-main">{{myCoupons.length}}</text>
          <text class="metric-caption">张消费券已入账</text>
        </view>
        <text class="tiny-chip">查看权益</text>
      </view>
      <view class="list-card metric-row" bindtap="goToLottery">
        <view>
          <text class="metric-main">{{hasDrawnLottery ? '已抽奖' : '待抽奖'}}</text>
          <text class="metric-caption">抽奖在独立页面进行</text>
        </view>
        <text class="tiny-chip">进入抽奖页</text>
      </view>
    </view>
  </view>

  <view class="section-head stagger-item stage-4">
    <text class="section-title">活动规则</text>
    <text class="section-subtitle">发放与使用说明</text>
  </view>
  <view class="list-stack stagger-item stage-4">
    <view class="list-card" wx:for="{{activityRules}}" wx:key="index">
      <text class="rule-text">{{index + 1}}. {{item}}</text>
    </view>
  </view>

  <view class="quick-grid stagger-item stage-4">
    <view class="quick-card surface-card" bindtap="goToPolicy">
      <text class="quick-icon">策</text>
      <text class="quick-title">政策清单</text>
      <text class="quick-text">快速查看就业、安居和补贴支持</text>
    </view>
    <view class="quick-card surface-card" bindtap="goToProfile">
      <text class="quick-icon">我</text>
      <text class="quick-title">个人中心</text>
      <text class="quick-text">查看红包、消费券和抽奖状态</text>
    </view>
  </view>

  <view wx:if="{{posterPopupVisible}}" class="poster-popup">
    <view class="poster-popup-mask" catchtap="closePosterPopup"></view>
    <view class="poster-popup-panel" catchtap="noop">
      <view class="poster-card poster-modal-card {{posterPopupType === 'redpacket' ? 'float-pulse' : ''}}">
        <text class="hero-kicker poster-kicker">{{posterPopupType === 'share' ? '分享海报' : '红包海报'}}</text>
        <text class="poster-headline">{{posterPopup.headline}}</text>
        <text class="poster-title">{{posterPopup.title}}</text>
        <view class="poster-amount-row">
          <text class="poster-currency">¥</text>
          <text class="poster-amount">{{posterPopup.amount}}</text>
        </view>
        <text class="poster-blessing">{{posterPopup.blessing}}</text>
        <text class="poster-footer">{{posterPopup.footer}}</text>
      </view>

      <view class="glass-card poster-popup-actions">
        <button wx:if="{{posterPopupType === 'share'}}" class="primary-btn" open-type="share">立即分享海报</button>
        <button wx:else class="primary-btn" bindtap="goToResult">查看荣誉卡片</button>

        <view class="poster-quick-actions">
          <button class="secondary-btn mini-btn" bindtap="openRandomPoster">随机换一张</button>
          <button wx:if="{{posterPopupType === 'share'}}" class="secondary-btn mini-btn" bindtap="openRedpacketPoster">切到红包海报</button>
          <button wx:else class="secondary-btn mini-btn" bindtap="openSharePoster">切到分享海报</button>
        </view>

        <button class="secondary-btn" bindtap="closePosterPopup">收起海报</button>
        <button class="secondary-btn mini-btn" bindtap="generateAndUploadPoster">保存并上云</button>
      </view>
    </view>
  </view>

  <canvas type="2d" id="posterCanvas" style="width: 300px; height: 500px; position: fixed; left: -9999px;"></canvas>

  <view wx:if="{{booting}}" class="startup-overlay">
    <view class="startup-card">
      <view class="startup-spinner"></view>
      <view class="startup-copy">
        <text class="startup-title">三江青年加载中</text>
        <text class="startup-desc">正在进入宜宾青春福袋...</text>
      </view>
    </view>
  </view>
</view>
