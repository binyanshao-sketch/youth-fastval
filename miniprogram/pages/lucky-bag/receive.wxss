.receive-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.receive-hero {
  padding: 30rpx;
}

.receive-kicker {
  background: rgba(16, 130, 190, 0.14);
  color: #0f6ea5;
}

.receive-title {
  display: block;
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #163b63;
}

.receive-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #6f879a;
}

.bag-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.bag-card {
  position: relative;
  min-height: 240rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #1896d2 0%, #138a95 100%);
  box-shadow: 0 18rpx 30rpx rgba(19, 117, 161, 0.2);
}

.bag-card.active {
  transform: translateY(-10rpx) scale(1.02);
  box-shadow: 0 20rpx 34rpx rgba(19, 117, 161, 0.28);
}

.bag-knot {
  width: 72rpx;
  height: 22rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #7be3f2 0%, #44c89e 100%);
}

.bag-body {
  min-height: 150rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  text-align: center;
}

.bag-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 22rpx;
  background: rgba(236, 252, 255, 0.2);
  color: #eefbff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bag-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #f2fcff;
}

.bag-tag {
  font-size: 20rpx;
  color: rgba(242, 252, 255, 0.8);
}

.bag-selected {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(227, 250, 255, 0.22);
  color: #f2fcff;
  font-size: 20rpx;
}

.opening-card {
  padding: 28rpx;
}

.privacy-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 22rpx 0 28rpx;
}

.privacy-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(16, 130, 190, 0.26);
  background: rgba(255, 255, 255, 0.86);
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.privacy-check.checked {
  background: linear-gradient(135deg, #0f79ba 0%, #26b892 100%);
  color: #fff;
  border-color: transparent;
}

.privacy-text {
  flex: 1;
  font-size: 24rpx;
  color: #6f879a;
}

.privacy-link {
  font-size: 24rpx;
  color: #0f6ea5;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(10, 46, 72, 0.34);
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
}

.sheet-panel {
  width: 100%;
  padding: 32rpx 28rpx;
  border-radius: 34rpx;
  background: #f5fdff;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #163b63;
}

.sheet-desc {
  font-size: 24rpx;
  line-height: 1.8;
  color: #6f879a;
  margin-bottom: 8rpx;
}
