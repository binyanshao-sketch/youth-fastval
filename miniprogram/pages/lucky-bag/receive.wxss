.receive-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.receive-hero {
  padding: 30rpx;
}

.receive-kicker {
  background: rgba(214, 74, 33, 0.12);
  color: #c04f21;
}

.receive-title {
  display: block;
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #2f231d;
}

.receive-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #8d6b59;
}

.bag-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.bag-card {
  position: relative;
  min-height: 240rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #e34f26 0%, #b93516 100%);
  box-shadow: 0 18rpx 30rpx rgba(181, 53, 22, 0.18);
}

.bag-card.active {
  transform: translateY(-10rpx) scale(1.02);
  box-shadow: 0 20rpx 34rpx rgba(181, 53, 22, 0.26);
}

.bag-knot {
  width: 72rpx;
  height: 22rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffd469 0%, #f2a623 100%);
}

.bag-body {
  min-height: 150rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.08));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  text-align: center;
}

.bag-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 22rpx;
  background: rgba(255, 240, 229, 0.18);
  color: #fff1e5;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bag-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff7ef;
}

.bag-tag {
  font-size: 20rpx;
  color: rgba(255, 247, 239, 0.78);
}

.bag-selected {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 232, 0.18);
  color: #fff8f2;
  font-size: 20rpx;
}

.opening-card {
  padding: 28rpx;
}

.privacy-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 22rpx 0 28rpx;
}

.privacy-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(214, 74, 33, 0.24);
  background: rgba(255, 255, 255, 0.86);
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.privacy-check.checked {
  background: linear-gradient(135deg, #d84b20 0%, #f6a332 100%);
  color: #fff;
  border-color: transparent;
}

.privacy-text {
  flex: 1;
  font-size: 24rpx;
  color: #6e574a;
}

.privacy-link {
  font-size: 24rpx;
  color: #c55222;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(31, 16, 9, 0.34);
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
}

.sheet-panel {
  width: 100%;
  padding: 32rpx 28rpx;
  border-radius: 34rpx;
  background: #fffaf6;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2f231d;
}

.sheet-desc {
  font-size: 24rpx;
  line-height: 1.8;
  color: #8d6b59;
  margin-bottom: 8rpx;
}
