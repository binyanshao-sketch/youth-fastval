<!--pages/lucky-bag/receive.wxml-->
<view class="container">
  <view class="receive-box">
    <image class="receive-bg" src="/images/receive-bg.png" mode="aspectFill"></image>
    
    <view class="receive-content">
      <text class="receive-title">请先授权手机号</text>
      <text class="receive-desc">用于发放红包和消费券核销</text>
      
      <!-- 手机号授权按钮 -->
      <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
        <text class="phone-btn-text">授权手机号</text>
      </button>
      
      <view class="privacy-tips">
        <checkbox checked="{{agreePrivacy}}" bindtap="togglePrivacy" color="#E54D42"/>
        <text class="privacy-text" bindtap="togglePrivacy">我已阅读并同意</text>
        <text class="privacy-link" bindtap="goToPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
