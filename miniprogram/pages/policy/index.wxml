<!--pages/policy/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <image class="header-bg" src="/images/policy-bg.png" mode="aspectFill"></image>
    <view class="header-content">
      <text class="header-title">宜宾青年政策一本通</text>
      <text class="header-subtitle">助力青年成长成才</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-bar" scroll-x>
    <view 
      class="category-item {{currentCategory === '' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-category=""
    >
      全部
    </view>
    <view 
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="switchCategory"
      data-category="{{item.id}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 政策列表 -->
  <view class="policy-list">
    <view class="policy-item" wx:for="{{policies}}" wx:key="id" bindtap="viewPolicy" data-id="{{item.id}}">
      <view class="policy-icon">
        <text>{{item.icon}}</text>
      </view>
      
      <view class="policy-content">
        <view class="policy-title">{{item.title}}</view>
        <view class="policy-summary">{{item.summary}}</view>
        <view class="policy-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
      
      <text class="policy-arrow">›</text>
    </view>
  </view>
</view>
