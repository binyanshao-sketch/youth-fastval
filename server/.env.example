# 后端开发环境配置
NODE_ENV=development

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yibin_youth_festival
DB_USER=root
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (至少 24 位)
JWT_SECRET=dev_secret_at_least_24_chars!!

# CORS
CORS_ORIGINS=http://localhost:5173

# 微信（开发环境使用 mock）
WX_USE_MOCK=true
WX_APPID=wx_dev_appid
WX_SECRET=wx_dev_secret
WX_PAY_MCHID=
WX_PAY_KEY=
WX_PAY_CERT_PATH=
WX_PAY_KEY_PATH=
WX_PAY_SPBILL_IP=

# 微信公众号 H5 OAuth（非微信浏览器可不配置，留空则回退到短信登录）
WX_H5_APPID=
WX_H5_SECRET=

# 七牛云 CDN（用于图片上传与 CDN 加速，不配置则上传功能不可用）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_CDN_DOMAIN=https://cdn.yourdomain.com
# 上传节点（华东：up-z0，华北：up-z1，华南：up-z2，北美：up-na0，东南亚：up-as0）
QINIU_UPLOAD_URL=https://up-z2.qiniup.com

# 腾讯云 SMS（开发环境不需要真实配置）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SIGN=
