# 后端开发环境配置
NODE_ENV=development

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yibin_youth_festival
DB_USER=root
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (至少 24 位)
JWT_SECRET=dev_secret_at_least_24_chars!!

# CORS
CORS_ORIGINS=http://localhost:5173

# 微信（开发环境使用 mock）
WX_USE_MOCK=true
WX_APPID=wx_dev_appid
WX_SECRET=wx_dev_secret
WX_PAY_MCHID=
WX_PAY_KEY=
WX_PAY_CERT_PATH=
WX_PAY_KEY_PATH=
WX_PAY_SPBILL_IP=

# 腾讯云 SMS（开发环境不需要真实配置）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SIGN=
