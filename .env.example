# ====================================
# 数据库配置
# ====================================
DB_ROOT_PASSWORD=your_root_password_here
DB_PASSWORD=your_app_password_here

# ====================================
# Redis
# ====================================
REDIS_PASSWORD=your_redis_password_here

# ====================================
# JWT (至少 24 位随机字符串)
# ====================================
JWT_SECRET=your_random_secret_key_at_least_24_chars

# ====================================
# CORS（逗号分隔的允许来源）
# ====================================
CORS_ORIGINS=https://yibin-youth.com,https://www.yibin-youth.com

# ====================================
# 微信小程序
# ====================================
WX_APPID=wx1234567890
WX_SECRET=abcdef123456
WX_USE_MOCK=false

# ====================================
# 微信支付
# ====================================
WX_PAY_MCHID=123456789
WX_PAY_KEY=your_32_char_payment_key

# ====================================
# 腾讯云 SMS
# ====================================
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_SMS_APP_ID=1400123456
TENCENT_SMS_TEMPLATE_ID=123456
TENCENT_SMS_SIGN=你的签名
